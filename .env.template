# ─── Trading-AI Environment Variables ─────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# ─── MT5 / Exness ────────────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial

# ─── Telegram Alerts ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── News API ────────────────────────────────────────────
NEWS_API_KEY=

# ─── Proxy (for Telegram in restricted regions) ─────────
# Format: socks5h://user:pass@host:port
PROXY_URL=

# ─── Ollama Local LLM ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Trading Configuration ───────────────────────────────
ACTIVE_MARKET=EURUSD
TRADING_MODE=demo

# ─── Dashboard ───────────────────────────────────────────
# bcrypt hash of your dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD_HASH=
